---
import BaseLayout from '../layouts/BaseLayout.astro';
import RatingFlow from '../components/RatingFlow';
import RevealGate from '../components/RevealGate';
import { ChevronLeft } from 'lucide-react';
import { getRecommendationById } from '../lib/recommendations';
import { getReactionsByRecommendation } from '../lib/reactions';

const { searchParams } = Astro.url;
const id = searchParams.get('id');
const view = searchParams.get('view');

let recommendation: Awaited<ReturnType<typeof getRecommendationById>> | null = null;
let reactions: Record<string, unknown>[] = [];

if (id) {
    recommendation = await getRecommendationById(id);
    reactions = await getReactionsByRecommendation(id);
}
---

<BaseLayout title={view ? "Friend's Reveal" : "Your Rating"}>
    <div class="flex flex-col gap-12 pt-12">
        <header class="flex flex-col gap-4">
             <a href="/guide" class="group flex items-center gap-2 text-brand-muted hover:text-totes-turquoise transition-colors w-fit">
                <ChevronLeft size={16} className="transition-transform group-hover:-translate-x-1" />
                <span class="text-[10px] font-urbanist font-bold tracking-[0.2em] uppercase text-brand-muted/50">Back to Guide</span>
            </a>
            <h1 class="text-xs font-urbanist font-bold tracking-[0.3em] uppercase text-brand-muted">
                Post-Watch <span class="text-totes-turquoise">Reveal</span>
            </h1>
        </header>

        {(view && recommendation) ? (
            <RevealGate client:load recommendation={recommendation} reactions={reactions} />
        ) : (
            <RatingFlow client:load recId={id} />
        )}

        {(!recommendation && id) && (
            <div class="py-20 text-center">
                <p class="text-brand-muted">Recommendation not found.</p>
            </div>
        )}
    </div>
</BaseLayout>
