# Copy to `.env` (gitignored) and fill in values.
# `.env.example` is committed; `.env` / `.env.local` / `.env.production` are not.

# --- Required ---

# Neon Postgres connection string (HTTPS serverless driver).
# Example: postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/watchr?sslmode=require
DATABASE_URL=

# --- Optional: Loops transactional email ---
# If any of these are missing, email notifications silently no-op (console.warn in dev only).

LOOPS_API_KEY=
LOOPS_NEW_REC_TEMPLATE_ID=
LOOPS_REVEAL_READY_TEMPLATE_ID=

# Two-user prototype routing — target addresses for the "A" and "B" users.
USER_A_EMAIL=
USER_B_EMAIL=

# Absolute URL embedded inside email bodies (so links work from an inbox).
# Dev default: http://localhost:4321
# Prod: your Vercel deployment URL (e.g. https://watchr.vercel.app)
PUBLIC_APP_URL=http://localhost:4321
